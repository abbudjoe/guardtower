{
  "scan_roots": [
    "/Users/joseph"
  ],
  "report_dir": "/Users/joseph/.codex/guardtower/reports",
  "state_dir": "/Users/joseph/.codex/guardtower/state",
  "env_file": "/Users/joseph/guard/.env",
  "deployment_status": [
    {
      "path_prefix": "/Users/joseph/llm-viz",
      "status": "unknown",
      "notes": "Set to deployed/staging/local/archived after confirming runtime status."
    }
  ],
  "deployment_discovery": {
    "vercel": {
      "enabled": true,
      "token_env": "VERCEL_TOKEN",
      "team_id_env": "VERCEL_TEAM_ID",
      "team_slug_env": "VERCEL_TEAM_SLUG",
      "projects": [
        {
          "path_prefix": "/Users/joseph/liquidshell/apps/web",
          "project_name": "liquidshell"
        }
      ]
    }
  },
  "max_depth": 5,
  "discover_git_roots": true,
  "git_root_search_depth": 3,
  "exclude_hidden_dirs": true,
  "exclude_dirs": [
    ".cache",
    ".git",
    ".next",
    ".npm",
    ".pnpm-store",
    ".venv",
    ".agents",
    ".bun",
    ".cargo",
    ".claude",
    ".codex",
    ".codex-control-noskill",
    ".codex-sidekick",
    ".config",
    ".docker",
    ".local",
    ".pixi",
    ".Trash",
    "Library",
    "Applications",
    "Desktop",
    "Documents",
    "Downloads",
    "Movies",
    "Music",
    "Pictures",
    "node_modules",
    "site-packages",
    "target",
    "vendor"
  ],
  "manifest_names": [
    "package.json",
    "package-lock.json",
    "npm-shrinkwrap.json",
    "pyproject.toml",
    "requirements.txt",
    "poetry.lock",
    "Pipfile.lock",
    "go.mod",
    "Cargo.lock",
    "Gemfile.lock"
  ],
  "threat_intel": {
    "days_back": 3,
    "include_cisa_kev": true,
    "include_nvd_recent": true,
    "include_osv": true,
    "osv_query_versionless": false,
    "include_rss": true,
    "rss_urls": [
      "https://www.cisa.gov/news.xml",
      "https://www.bleepingcomputer.com/feed/",
      "https://thehackernews.com/feeds/posts/default",
      "https://www.securityweek.com/feed/"
    ],
    "x_recent_search": {
      "enabled": true,
      "bearer_token_env": "X_BEARER_TOKEN",
      "max_results_per_query": 10,
      "queries": [
        "(\"zero day\" OR \"0day\" OR CVE) (exploit OR exploited OR vulnerability OR RCE) -newsletter -\"top AI news\" -roundup -is:retweet lang:en",
        "\"supply chain\" (npm OR PyPI) (compromised package OR malicious package OR exploit) -newsletter -roundup -is:retweet lang:en",
        "\"Next.js\" (advisory OR CVE OR vulnerability OR exploit) -newsletter -roundup -is:retweet lang:en",
        "\"GitHub Actions\" \"cache poisoning\" (package OR exploit OR compromised) -newsletter -roundup -is:retweet lang:en"
      ]
    }
  },
  "watched_surfaces": [
    {
      "id": "nextjs",
      "names": [
